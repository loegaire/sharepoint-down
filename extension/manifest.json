{
  "manifest_version": 3,
  "name": "SharePoint Opened PDF Downloader",
  "description": "Download the currently opened SharePoint PDF after you click the extension button.",
  "version": "0.4.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Download opened SharePoint PDF",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "debugger",
    "downloads",
    "scripting",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.sharepoint.com/*",
    "https://*.sharepoint-df.com/*",
    "https://*.sharepointonline.com/*",
    "https://*.officeapps.live.com/*",
    "https://mediap.svc.ms/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.sharepoint.com/*",
        "https://*.sharepoint-df.com/*",
        "https://*.sharepointonline.com/*",
        "https://*.officeapps.live.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
